{
  "extends": "@hrms-app/typescript-config/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@db/*": ["../../packages/db/src/*"],
      "@auth/*": ["../../packages/auth/src/*"],
      "@validators/*": ["../../packages/validators/src/*"],
      "@config/*": ["../../packages/config/src/*"],
      "@email/*": ["../../packages/email/src/*"]
    },
    "jsx": "preserve"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
