# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hrms-app"

# Auth
AUTH_SECRET="change-me-to-a-random-64-char-string"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Enables the fixed demo credentials only when explicitly set to true.
DEMO_MODE="false"

# Redis (for queue + rate limiting)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY=""

# Rate limiting (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Monitoring (Sentry)
SENTRY_DSN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional deploy-time white label. Leave blank to use Taāzur / تآزر.
NEXT_PUBLIC_BRAND_NAME=""
NEXT_PUBLIC_BRAND_NAME_AR=""
NEXT_PUBLIC_BRAND_LOGO_URL=""
NEXT_PUBLIC_BRAND_ACCENT=""
NEXT_PUBLIC_BRAND_ATTRIBUTION=""
NODE_ENV="development"
